# Supabase 또는 PostgreSQL 연결 문자열
# 이 파일을 apps/server/.env로 복사 후 실제 값으로 수정하세요
# cp .env.example apps/server/.env

DATABASE_URL=postgresql://postgres.xxx:YOUR_PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres
PORT=5005

# 카카오톡 공유 (클라이언트용 - apps/client/.env 또는 Vercel 환경변수)
# developers.kakao.com 에서 앱 생성 후 JavaScript 키 발급
# VITE_KAKAO_JS_KEY=your_kakao_javascript_key
